{
  "name": "stock-tracker",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:mobile": "turbo run dev --filter=@stock-tracker/mobile",
    "dev:api": "turbo run dev --filter=@stock-tracker/api",
    "dev:subgraph": "turbo run dev --filter=@stock-tracker/subgraph-tracker",
    "dev:router": "turbo run dev --filter=@stock-tracker/router",
    "dev:backend": "turbo run dev --filter=@stock-tracker/router --filter=@stock-tracker/subgraph-tracker --filter=@stock-tracker/api",
    "dev:storybook": "turbo run storybook --filter=@stock-tracker/storybook",
    "db:generate": "turbo run db:generate --filter=@stock-tracker/prisma",
    "db:push": "npm run db:push --workspace=@stock-tracker/prisma",
    "db:migrate:dev": "npm run db:migrate:dev --workspace=@stock-tracker/prisma",
    "db:studio": "npm run db:studio --workspace=@stock-tracker/prisma",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "ajv": "^8.18.0",
    "jest-junit": "^16.0.0",
    "lost-pixel": "^3.22.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.7.4",
    "sharp": "^0.34.5",
    "turbo": "^2.8.20",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "apps/subgraphs/*",
    "packages/*"
  ],
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "ajv-keywords": {
      "ajv": "^8.17.1"
    },
    "schema-utils": {
      "ajv": "^8.17.1"
    }
  }
}
