model auth_users {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supabase_id  String   @unique @db.Uuid
  email        String   @unique
  display_name String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  tracker_accounts tracker_accounts[]
}
