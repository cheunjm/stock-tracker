{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "node": "20.19.4"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-develop-97e5.up.railway.app"
      }
    },
    "development:simulator": {
      "extends": "development",
      "ios": {
        "simulator": true
      }
    },
    "storybook": {
      "extends": "development",
      "env": {
        "STORYBOOK_ENABLED": "true"
      }
    },
    "preview": {
      "extends": "base",
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-stage-9c63.up.railway.app"
      }
    },
    "production": {
      "extends": "base",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_GRAPHQL_URL": "https://router-production-1e15.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "jaemin@cheunjm.com",
        "ascAppId": "TODO",
        "appleTeamId": "2ZM4PS6CMF"
      }
    }
  }
}
